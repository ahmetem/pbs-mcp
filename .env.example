# pbs-mcp configuration
# Copy this file to .env and fill in real values. The .env file is gitignored.

# Proxmox Backup Server REST endpoint (no trailing slash)
PBS_HOST=https://192.168.1.27:8007

# API token in the form `user@realm!tokenname`
PBS_TOKEN_ID=root@pam!mcp

# Token secret (UUID). Generate with:
#   proxmox-backup-manager user generate-token root@pam mcp
PBS_TOKEN_SECRET=replace-with-real-uuid-secret

# PBS node name as it appears in the task UPID (usually 'pbs' or the hostname).
# Needed for task status / log endpoints.
PBS_NODE=pbs

# TLS verification. PBS uses a self-signed cert by default; set to 'false' for that.
# If you have installed a real CA cert, set 'true' and (optionally) PBS_CA_BUNDLE
# to the path of a PEM file.
PBS_VERIFY_TLS=false
# PBS_CA_BUNDLE=/etc/ssl/certs/my-ca.pem

# Optional: default datastore for tools that accept an omitted `datastore`
# parameter. If a tool is called without `datastore`, this is used.
PBS_DEFAULT_DATASTORE=wdmycloud

# Request timeout in seconds for normal (non-task) API calls.
PBS_HTTP_TIMEOUT=30

# Write-side toggle. When false, all S2 tools (run_gc, run_verify, prune,
# forget_snapshot) refuse to run regardless of confirm flags. Default false.
PBS_ALLOW_WRITE=false
